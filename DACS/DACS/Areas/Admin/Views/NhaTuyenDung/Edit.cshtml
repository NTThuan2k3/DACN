@model DACS.Models.NhaTuyenDung

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}
<div class="container">
    <h1>Chỉnh sửa</h1>

    <h4>Nhà thông tin nhà tuyển dụng</h4>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <div class="form-group pt-2">
                    <label asp-for="TenNTD" class="control-label">Tên nhà tuyển dụng</label>
                    <input asp-for="TenNTD" class="form-control" />
                    <span asp-validation-for="TenNTD" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <label asp-for="SDT" class="control-label"></label>
                    <input asp-for="SDT" class="form-control" />
                    <span asp-validation-for="SDT" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <label asp-for="TinhId" class="control-label">Tỉnh</label>
                    <select asp-for="TinhId" class="form-control" asp-items="ViewBag.Tinh"></select>
                    <span asp-validation-for="TinhId" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <label asp-for="DiaDiem" class="control-label">Địa chỉ</label>
                    <input asp-for="DiaDiem" class="form-control" />
                    <span asp-validation-for="DiaDiem" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <label asp-for="Email" class="control-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <label asp-for="ImageDaiDien">Ảnh đại diện</label>
                    <input type="file" asp-for="ImageDaiDien" name="image1" class="form-control" id="imageInput1" />
                </div>
                <div class="col-8">
                    <img src="@Model.ImageDaiDien" alt="Image Dai Dien" style="max-width:200px;" id="previewImageDaiDien" />
                </div>
                <div class="form-group pt-2">
                    <label asp-for="ImageBangTin">Ảnh đăng tin</label>
                    <input type="file" asp-for="ImageBangTin" name="image2" class="form-control" id="imageInput2" />
                </div>
                <div class="col-8">
                    <img src="@Model.ImageBangTin" alt="Image Bang Tin" style="max-width:200px;" id="previewImageBangTin" />
                </div>
                <div class="form-group pt-2">
                    <label asp-for="Website" class="control-label"></label>
                    <input asp-for="Website" class="form-control" />
                    <span asp-validation-for="Website" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <label asp-for="QuyMo" class="control-label">Quy mô</label>
                    <input asp-for="QuyMo" class="form-control" />
                    <span asp-validation-for="QuyMo" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <label asp-for="MoTa" class="control-label">Mô tả</label>
                    <input asp-for="MoTa" class="form-control" />
                    <span asp-validation-for="MoTa" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <label asp-for="StatusId" class="control-label">Trạng thái</label>
                    <select asp-for="StatusId" class="form-control" asp-items="ViewBag.Status"></select>
                    <span asp-validation-for="StatusId" class="text-danger"></span>
                </div>
                <div class="form-group pt-2">
                    <input type="submit" value="Lưu" class="btn btn-primary" />
                </div>
            </form>

            <script>
                document.querySelectorAll('input[type="file"]').forEach(input => {
                    input.addEventListener('change', function (event) {
                        const file = event.target.files[0];
                        if (file) {
                            const reader = new FileReader();
                            reader.onload = function (e) {
                                const imgId = event.target.id === "imageInput1" ? "previewImageDaiDien" : "previewImageBangTin";
                                const img = document.getElementById(imgId);
                                img.src = e.target.result;
                            };
                            reader.readAsDataURL(file);
                        }
                    });
                });
            </script>

        </div>
    </div>

    @* <div>
        <a asp-action="Index">Back to List</a>
    </div> *@
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
