@model IEnumerable<DACS.Models.PhieuDangTuyen>

@{
    ViewData["Title"] = "IndexCaNhan";
	Layout = "~/Areas/Employer/Views/Shared/_Layout.cshtml";
}

<!-- Start banner Area -->
<section class="banner-area relative" id="home">
    <div class="overlay overlay-bg"></div>
    <div class="container">
        <div class="row search-page-top d-flex align-items-center justify-content-center">
            <div class="banner-content col-lg-12">
                <h1 class="text-white">
                    Tìm Kiếm Việc Làm
                </h1>
                <!--Search box-->
                @* @Html.Partial("../Shared/_SearchBoxPartial.cshtml")
                <p style="font-size: 20px" class="text-white"> <span>Search by tags:</span> Developer, Engineer, Technology, Support, Manager, Senior, Junior</p> *@
            </div>
        </div>
    </div>
</section>
<!-- End banner Area -->

<div class="pt-20 container">
	<h1>Danh sách các phiếu tuyển dụng</h1>
	<div class="pt-10">
		<table class="table">
			<thead>
				<tr>
					<th>
						@* @Html.DisplayNameFor(model => model.TenNganh) *@
						Tên Ngành
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.MucLuong) *@
						Mức Lương
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.NamKN) *@
						Năm Kinh Nghiệm
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.Tinhs) *@
						Tỉnh Thành
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.TenViecLam) *@
						Tên Việc Làm
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.ChucDanh) *@
						Chức Danh
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.MoTa) *@
						Mô tả
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.DiaDiem) *@
						Địa Chỉ
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.NgayLapPhieu) *@
						Ngày Lập Phiếu
					</th>
					<th>
						@* @Html.DisplayNameFor(model => model.HanNopHoSo) *@
						Hạn Phiếu
					</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model)
				{
					<tr>
						<td>
							@Html.DisplayFor(modelItem => item.TenNganh)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.MucLuong)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.NamKN)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.Tinhs.TenTinh)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.TenViecLam)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.ChucDanh)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.MoTa)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.DiaDiem)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.NgayLapPhieu)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.HanNopHoSo)
						</td>
						<td>
							<a class="btn btn-primary" asp-controller="DonUngTuyen" asp-action="DetailsPhieu" asp-route-id="@item.Id">Các Đơn Đã Nhận</a>
							<a class="btn btn-danger" asp-controller="DonUngTuyen" asp-action="Delete" asp-route-id="@item.Id">Xóa phiếu</a>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
	<a class="btn btn-primary" asp-action="Create">Đăng Tuyển</a>
</div>


